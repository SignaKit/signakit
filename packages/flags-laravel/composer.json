{
  "name": "signakit/flags-laravel",
  "description": "Laravel integration for SignaKit Feature Flags",
  "type": "library",
  "version": "1.1.0",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "signakit/flags-php": "^1.0",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "SignaKit\\FlagsLaravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SignaKit\\FlagsLaravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SignaKit\\FlagsLaravel\\SignaKitServiceProvider"
      ],
      "aliases": {
        "SignaKit": "SignaKit\\FlagsLaravel\\Facades\\SignaKit"
      }
    }
  },
  "minimum-stability": "stable"
}
